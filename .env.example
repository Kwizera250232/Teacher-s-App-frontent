# Frontend Environment Variables
# Copy this file to .env for local development

# API URL - Leave empty for production (uses default from api.js)
# For local development: VITE_API_URL=http://localhost:5000/api
VITE_API_URL=

# Uploads URL - Leave empty for production (uses default from api.js)
# For local development: VITE_UPLOADS_URL=http://localhost:5000
VITE_UPLOADS_URL=

# Base path for deployment (e.g., /subdirectory)
VITE_BASE_PATH=/
