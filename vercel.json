{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://studentapi.umunsi.com/api/:path*"
    },
    {
      "source": "/download/:path*",
      "destination": "https://studentapi.umunsi.com/download/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://studentapi.umunsi.com/uploads/:path*"
    },
    {
      "source": "/share/moment/:token/preview.jpg",
      "destination": "https://studentapi.umunsi.com/share/moment/:token/preview.jpg"
    },
    {
      "source": "/share/moment/:token",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|WhatsApp|LinkedInBot|Slackbot|TelegramBot|Discordbot).*"
        }
      ],
      "destination": "https://studentapi.umunsi.com/share/moment/:token"
    },
    { "source": "/((?!assets|uploads|favicon.ico).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
